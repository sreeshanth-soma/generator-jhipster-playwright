import { test, expect } from '@playwright/test';
import {
  emailResetPasswordSelector,
  submitInitResetPasswordSelector,
} from '../../support/commands';

test.describe('reset password page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/account/reset/request');
  });

  test('requires email', async ({ page }) => {
<%_ if (clientFrameworkReact) { _%>
    await page.locator(submitInitResetPasswordSelector).click({ force: true });
<%_ } else { _%>
    await page.locator(submitInitResetPasswordSelector).click();
<%_ } _%>
    await expect(page.locator(emailResetPasswordSelector)).toBeVisible();
  });

  test('should show success message on valid email', async ({ page }) => {
    await page.locator(emailResetPasswordSelector).fill('admin@localhost');
<%_ if (clientFrameworkReact) { _%>
    await page.locator(submitInitResetPasswordSelector).click({ force: true });
<%_ } else { _%>
    await page.locator(submitInitResetPasswordSelector).click();
<%_ } _%>
    // Success or info message
    await expect(page.locator('.alert-success, .alert-warning')).toBeVisible({ timeout: 10000 });
  });
});
