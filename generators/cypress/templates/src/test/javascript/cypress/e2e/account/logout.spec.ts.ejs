  Source EJS variables: authenticationUsesCsrf
-%>
import { test, expect } from '@playwright/test';
import {
  accountMenuSelector,
  navbarSelector,
  loginItemSelector,
  credentials,
} from '../../support/commands';
import { clickOnLogoutItem } from '../../support/navbar';
import { login } from '../../support/commands';

test.describe('logout', () => {
  let username: string;
  let password: string;

  test.beforeAll(() => {
    const creds = credentials();
    username = creds.username;
    password = creds.password;
  });

  test('go to home page when successfully logs out', async ({ page, request }) => {
    await login(page, request, username, password);
    await page.goto('/');

    await clickOnLogoutItem(page);

<%_ if (authenticationUsesCsrf) { _%>
    // Wait for CSRF logout POST
    await page.waitForResponse('**/api/logout');
<%_ } _%>
    await expect(
      page.locator(navbarSelector).locator(accountMenuSelector).locator(loginItemSelector)
    ).toBeVisible();
  });
});
