import { test, expect } from '@playwright/test';
import {
  accountMenuSelector,
  credentials,
  login,
  loginItemSelector,
  navbarSelector,
} from '../../support/commands';
import { clickOnLogoutItem } from '../../support/navbar';

test.describe('logout', () => {
  let username: string;
  let password: string;

  test.beforeAll(() => {
    const creds = credentials();
    username = creds.username;
    password = creds.password;
  });

  test('go to home page when successfully logs out', async ({ page, request }) => {
    await login(page, request, username, password);
    await page.goto('/');
<%_ if (authenticationUsesCsrf) { _%>
    // Wait for CSRF-protected logout to complete
    const logoutResponse = page.waitForResponse('**/api/logout');
<%_ } _%>
    await clickOnLogoutItem(page);
<%_ if (authenticationUsesCsrf) { _%>
    await logoutResponse;
<%_ } _%>
    // Wait for React to process the logout and show login item
    await page.locator(navbarSelector).locator(accountMenuSelector).waitFor({ state: 'visible', timeout: 10000 });
    await page.locator(navbarSelector).locator(accountMenuSelector).click();
    await expect(page.locator(navbarSelector).locator(accountMenuSelector).locator(loginItemSelector)).toBeVisible({ timeout: 10000 });
  });
});
