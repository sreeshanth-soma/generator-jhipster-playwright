export interface Credentials {
  adminUsername: string;
  adminPassword: string;
  username: string;
  password: string;
}

/**
 * Get test credentials from environment or defaults.
 */
export function credentials(): Credentials {
  return {
    adminUsername: process.env.E2E_USERNAME ?? '<%= adminUsername ?? "admin" %>',
    adminPassword: process.env.E2E_PASSWORD ?? '<%= adminPassword ?? "admin" %>',
    username: process.env.E2E_USERNAME ?? '<%= username ?? "user" %>',
    password: process.env.E2E_PASSWORD ?? '<%= password ?? "user" %>',
  };
}

/**
 * Login via API and return storage state for session reuse.
 */
export async function login(request: APIRequestContext, username: string, password: string): Promise<string> {
  // First hit /api/account to initialize the session
  await request.get('/api/account', { failOnStatusCode: false });

  const response = await request.post('<%= authenticationUrl ?? "/api/authenticate" %>', {
    data: { username, password },
  });

  const body = await response.json();
<%_ if (clientFrameworkVue) { _%>
  // Vue stores JWT as raw string
  return body.id_token;
<%_ } else { _%>
  return body.id_token;
<%_ } _%>
}

/**
 * Make an authenticated API request.
 */
export async function authenticatedRequest(
  request: APIRequestContext,
  options: {
    method?: string;
    url: string;
    data?: unknown;
  },
) {
  const { method = 'GET', url, data } = options;

  // Get token from storage state (set during login)
  const token = process.env.__JWT_TOKEN__;

  const headers: Record<string, string> = {};
  if (token) {
    headers['Authorization'] = `Bearer ${token}`;
  }

  if (method === 'GET') {
    return request.get(url, { headers });
  } else if (method === 'POST') {
    return request.post(url, { headers, data });
  } else if (method === 'PUT') {
    return request.put(url, { headers, data });
  } else if (method === 'DELETE') {
    return request.delete(url, { headers });
  }

  return request.get(url, { headers });
}
